{
  "name": "portfolio-research-reader",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=26.5.0 <27"
  },
  "scripts": {
    "sync:data": "node scripts/sync-research-data.mjs",
    "predev": "pnpm run sync:data",
    "prebuild": "pnpm run sync:data",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "pnpm run build && node --import tsx --test tests/rendered-html.test.mjs tests/markdown-reader.test.tsx",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/mdast": "4.0.4",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "packageManager": "pnpm@11.13.0"
}
